{
    "devDependencies": {
        "@prettier/plugin-xml": "^3.4.2",
        "prettier": "^3.8.4",
        "prettier-plugin-apex": "^2.2.6"
    },
    "scripts": {
        "prettier:apex:check": "prettier --plugin=prettier-plugin-apex --check \"sfdx-source/apex-di/**/*.{trigger,cls}\"",
        "prettier:apex:diff": "prettier --plugin=prettier-plugin-apex --list-different \"sfdx-source/apex-di/**/*.{trigger,cls}\"",
        "prettier:apex:fix": "prettier --plugin=prettier-plugin-apex --write \"sfdx-source/apex-di/**/*.{trigger,cls}\"",
        "prettier:check": "prettier --check .",
        "prettier:diff": "prettier --list-different .",
        "prettier:fix": "prettier --write .",
        "sfca:check": "sf code-analyzer run --config-file ./code-analyzer.yml --workspace sfdx-source/apex-di",
        "sfca:check:detail": "sf code-analyzer run --config-file ./code-analyzer.yml --workspace sfdx-source/apex-di --view detail",
        "sf:push": "sf project deploy start",
        "sf:run:test:all": "sf apex run test -n DiTest --synchronous --code-coverage"
    }
}
